NODE_ENV=production
APP_PORT=4000
PORT=4000
BOT_TOKEN=123456:telegram-bot-token
BOT_USERNAME=your_bot_username
ADMIN_TG_IDS=111111111,222222222
ADMIN_TG_HANDLE=your_admin_username

POSTGRES_DB=vpn_bot
POSTGRES_USER=vpn_bot
POSTGRES_PASSWORD=vpn_bot_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://vpn_bot:vpn_bot_password@db:5432/vpn_bot?schema=public
RUN_SEED=false

REMNAWAVE_URL=http://localhost:3000
REMNAWAVE_TOKEN=your_remnawave_token
# Optional SOCKS5 proxy for ALL RemnaWave API calls.
# You can use full URL:
# REMNAWAVE_SOCKS5_URL=
# Or set host/port (+ optional auth):
# REMNAWAVE_SOCKS5_HOST=127.0.0.1
# REMNAWAVE_SOCKS5_PORT=10008
# REMNAWAVE_SOCKS5_USERNAME=lzH650MN4T
# REMNAWAVE_SOCKS5_PASSWORD=HatBPzd3aV
DEFAULT_INTERNAL_SQUAD_ID=1
LOGO_PATH=/app/logo.png

TETRA98_API_KEY=your_tetra98_api_key
MANUAL_CARD_NUMBER=6037990000000000
MANUAL_CARD_HOLDER_NAME="John Doe"
# Randomized amount threshold (percent) for manual card-to-card payments.
MANUAL_PAYMENT_LOWER_THRESHOLD_PERCENT=5
MANUAL_PAYMENT_UPPER_THRESHOLD_PERCENT=5

MIN_WALLET_CHARGE_TOMANS=10000
MAX_WALLET_CHARGE_TOMANS=10000000
